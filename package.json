{
  "name": "n8n-nodes-panda-free-llm",
  "version": "0.1.0",
  "description": "An n8n node that sends a prompt to multiple FREE LLM providers (Groq, Cerebras, Google Gemini, OpenRouter, Mistral) with automatic failover when one hits its rate limit or daily quota.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "llm",
    "ai",
    "groq",
    "gemini",
    "openrouter",
    "failover"
  ],
  "license": "MIT",
  "homepage": "https://github.com/YOUR_GITHUB/n8n-nodes-panda-free-llm",
  "author": {
    "name": "Mostafa",
    "email": "you@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_GITHUB/n8n-nodes-panda-free-llm.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PandaFreeLlmApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PandaFreeLlm/PandaFreeLlm.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "rimraf": "^5.0.5",
    "typescript": "^5.5.0"
  }
}
